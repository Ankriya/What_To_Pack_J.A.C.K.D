<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige"
    tools:context=".TripDetailsActivity">

    <ImageView
        android:id="@+id/background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:srcCompat="@drawable/blue_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <TextView
        android:id="@+id/TRIPDETAILS"
        android:layout_width="313dp"
        android:layout_height="89dp"
        android:layout_marginTop="36dp"
        android:fontFamily="@font/tantangkiwood_display"
        android:text="TRIP DETAILS"
        android:textColor="@color/black"
        android:textSize="60sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/currency_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        app:cardBackgroundColor="#99a1f7da"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/TRIPDETAILS"
        tools:layout_editor_absoluteX="5dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="364dp"
            android:layout_height="405dp"
            android:padding="16dp">

            <TextView
                android:id="@+id/From"
                android:layout_width="88dp"
                android:layout_height="35dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="50dp"
                android:fontFamily="@font/tantangkiwood_display"
                android:text="FROM:"
                android:textColor="@color/black"
                android:textSize="35sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <EditText
                android:id="@+id/FromInput"
                android:layout_width="157dp"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/rounded_edittext_bg"
                android:fontFamily="@font/tantangkiwood_display"
                android:hint="ENTER LOCATION"
                android:inputType="textPersonName"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/From" />

            <TextView
                android:id="@+id/To"
                android:layout_width="43dp"
                android:layout_height="35dp"
                android:layout_marginStart="180dp"
                android:layout_marginTop="50dp"
                android:fontFamily="@font/tantangkiwood_display"
                android:text="TO:"
                android:textColor="@color/black"
                android:textSize="35sp"
                app:layout_constraintLeft_toRightOf=""
                app:layout_constraintStart_toStartOf="parent"
                tools:ignore="MissingConstraints"
                tools:layout_editor_absoluteY="50dp" />

            <EditText
                android:id="@+id/ToInput"
                android:layout_width="157dp"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/rounded_edittext_bg"
                android:fontFamily="@font/tantangkiwood_display"
                android:hint="ENTER DESTINATION"
                android:inputType="textPersonName"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.937"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/To" />

            <TextView
                android:id="@+id/Amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="68dp"
                android:fontFamily="@font/tantangkiwood_display"
                android:text="TIME:"
                android:textColor="@color/black"
                android:textSize="35sp"
                app:layout_constraintTop_toBottomOf="@+id/To"
                tools:ignore="MissingConstraints"
                tools:layout_editor_absoluteX="126dp" />

            <EditText
                android:id="@+id/AmountInput"
                android:layout_width="157dp"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/rounded_edittext_bg"
                android:fontFamily="@font/tantangkiwood_display"
                android:hint="ENTER TIME"
                android:inputType="textPersonName"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.497"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/Amount" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp"
                android:fontFamily="@font/tantangkiwood_display"
                android:text="LOCATION:"
                android:textColor="@color/black"
                android:textSize="35sp"
                app:layout_constraintTop_toBottomOf="@+id/Amount"
                tools:ignore="MissingConstraints"
                tools:layout_editor_absoluteX="93dp" />

            <EditText
                android:layout_width="157dp"
                android:layout_height="45dp"
                android:background="@drawable/rounded_edittext_bg"
                android:fontFamily="@font/tantangkiwood_display"
                android:hint="ENTER AIRPORT"
                android:inputType="textPersonName"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.497"
                app:layout_constraintStart_toStartOf="parent"
                tools:ignore="MissingConstraints"
                tools:layout_editor_absoluteY="327dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="656dp"
                android:fontFamily="@font/tantangkiwood_display"
                android:text="TRIP DATES:"
                android:textColor="@color/black"
                android:textSize="32sp"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.455"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/SubmitBtn"
        android:layout_width="141dp"
        android:layout_height="56dp"
        android:backgroundTint="@color/pastelPurple"
        android:fontFamily="@font/tantangkiwood_display"
        android:text="SUBMIT"
        android:textColor="@android:color/black"
        android:textSize="30sp"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="135dp"
        tools:layout_editor_absoluteY="562dp" />

    <Button
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:backgroundTint="@color/pastelGreen"
        android:fontFamily="@font/tantangkiwood_display"
        android:text="VIEW TRIPS"
        android:textColor="@android:color/black"
        android:textSize="30sp"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="114dp"
        tools:layout_editor_absoluteY="637dp" />

</androidx.constraintlayout.widget.ConstraintLayout>