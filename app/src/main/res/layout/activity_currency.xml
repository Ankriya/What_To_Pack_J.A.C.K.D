<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige"
    tools:context=".CurrencyActivity">

    <ImageView
        android:id="@+id/background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:srcCompat="@drawable/blue_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <TextView
        android:id="@+id/Currency"
        android:layout_width="313dp"
        android:layout_height="89dp"
        android:layout_marginTop="36dp"
        android:fontFamily="@font/tantangkiwood_display"
        android:text="CURRENCY"
        android:textColor="@color/black"
        android:textSize="75sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/currency_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="85dp"
        app:cardBackgroundColor="#99a1f7da"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/Currency"
        tools:layout_editor_absoluteX="5dp"
        tools:layout_editor_absoluteY="252dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="364dp"
            android:layout_height="match_parent"
            android:padding="16dp">

            <TextView
                android:id="@+id/From"
                android:layout_width="88dp"
                android:layout_height="35dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/tantangkiwood_display"
                android:text="FROM:"
                android:textColor="@color/black"
                android:textSize="35sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <EditText
                android:id="@+id/FromInput"
                android:layout_width="157dp"
                android:layout_height="33dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/rounded_edittext_bg"
                android:fontFamily="@font/tantangkiwood_display"
                android:hint="ENTER CURRENCY"
                android:inputType="textPersonName"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/From" />

            <TextView
                android:id="@+id/To"
                android:layout_width="43dp"
                android:layout_height="35dp"
                android:layout_marginStart="180dp"
                android:fontFamily="@font/tantangkiwood_display"
                android:text="TO:"
                android:textColor="@color/black"
                android:textSize="35sp"
                app:layout_constraintLeft_toRightOf=""
                app:layout_constraintStart_toStartOf="parent"
                tools:ignore="MissingConstraints"
                tools:layout_editor_absoluteY="16dp" />

            <EditText
                android:id="@+id/ToInput"
                android:layout_width="157dp"
                android:layout_height="33dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/rounded_edittext_bg"
                android:fontFamily="@font/tantangkiwood_display"
                android:hint="ENTER CURRENCY"
                android:inputType="textPersonName"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.937"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/To" />

            <TextView
                android:id="@+id/Amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="88dp"
                android:layout_marginTop="60dp"
                android:fontFamily="@font/tantangkiwood_display"
                android:text="AMOUNT:"
                android:textColor="@color/black"
                android:textSize="35sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/To" />

            <EditText
                android:id="@+id/AmountInput"
                android:layout_width="157dp"
                android:layout_height="33dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/rounded_edittext_bg"
                android:fontFamily="@font/tantangkiwood_display"
                android:hint="ENTER AMOUNT"
                android:inputType="textPersonName"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.405"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/Amount" />

            <Button
                android:id="@+id/SubmitBtn"
                android:layout_width="141dp"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="@color/pastelRed"
                android:fontFamily="@font/tantangkiwood_display"
                android:text="SUBMIT"
                android:textColor="@android:color/black"
                android:textSize="30sp"
                app:layout_constraintTop_toBottomOf="@id/AmountInput"
                tools:ignore="MissingConstraints"
                tools:layout_editor_absoluteX="83dp" />

            <TextView
                android:id="@+id/ResultDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/tantangkiwood_display"
                android:text="Converted Result: R0.00"
                android:textColor="@color/black"
                android:textSize="32sp"
                android:visibility="visible"
                app:layout_constraintTop_toBottomOf="@id/SubmitBtn"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <ImageView
        android:id="@+id/Money"
        android:layout_width="107dp"
        android:layout_height="112dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/Currency"
        app:srcCompat="@drawable/money"
        tools:layout_editor_absoluteX="288dp"
        tools:ignore="MissingConstraints" />

    <ImageView
        android:id="@+id/Money2"
        android:layout_width="129dp"
        android:layout_height="143dp"
        android:layout_marginTop="444dp"
        app:layout_constraintTop_toBottomOf="@id/Currency"
        app:srcCompat="@drawable/money2"
        tools:ignore="MissingConstraints,NotSibling"
        tools:layout_editor_absoluteX="16dp" />


</androidx.constraintlayout.widget.ConstraintLayout>