<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ViewListDetailsActivity">

    <!-- Main content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/beige">

        <!-- Background -->
        <ImageView
            android:id="@+id/background"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            app:srcCompat="@drawable/blue_bg"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Hamburger menu button -->
        <ImageButton
            android:id="@+id/menu_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:contentDescription="Menu"
            android:elevation="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/black"/>

        <!-- Page title -->
        <TextView
            android:id="@+id/UserTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/tantangkiwood_display"
            android:text="@string/ViewListDetails"
            android:gravity="center"
            android:textColor="@color/black"
            android:textSize="50sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- List details card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/list_details_card"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="#99a1f7da"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:layout_constraintBottom_toTopOf="@id/EditProfilebtn"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/UserTitle"
            android:layout_marginBottom="32dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp">

                <!-- List Title -->
                <TextView
                    android:id="@+id/list_name_header"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/tantangkiwood_display"
                    android:text="@string/ListName"
                    android:textSize="30sp"
                    android:gravity="center"
                    android:textColor="@color/black"
                    android:paddingBottom="8dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <ImageButton
                    android:id="@+id/btn_edit_list"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/edit"
                    android:background="@android:color/transparent"
                    android:contentDescription="Edit list"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:padding="4dp"
                    app:layout_constraintTop_toTopOf="@id/list_name_header"
                    app:layout_constraintEnd_toStartOf="@id/btn_delete_list"
                    android:layout_marginEnd="8dp"/>

                <ImageButton
                    android:id="@+id/btn_delete_list"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/delete"
                    android:background="@android:color/transparent"
                    android:contentDescription="Delete list"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:padding="4dp"
                    app:layout_constraintTop_toTopOf="@id/list_name_header"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/list_items_recycler_view"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:paddingHorizontal="16dp"
                    tools:listitem="@layout/item_bullet_point"
                    app:layout_constraintTop_toBottomOf="@id/list_name_header"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/new_item_input_layout"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"/>

                <!-- New Item Input & Button -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/new_item_input_layout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxStrokeColor="#CCCCCC"
                    app:boxBackgroundColor="@android:color/white"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/add_item_btn"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginEnd="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/new_item_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/NewItem"
                        android:padding="12dp"
                        android:textColor="@android:color/black"/>
                </com.google.android.material.textfield.TextInputLayout>

                <ImageButton
                    android:id="@+id/add_item_btn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/add"
                    android:background="@android:color/transparent"
                    android:contentDescription="Add item"
                    app:tint="@null"
                    android:scaleType="centerInside"
                    app:layout_constraintBottom_toBottomOf="@id/new_item_input_layout"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/new_item_input_layout"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.cardview.widget.CardView>

        <!-- Back button -->
        <Button
            android:id="@+id/EditProfilebtn"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:layout_marginBottom="32dp"
            android:backgroundTint="@color/pastelGreen"
            android:fontFamily="@font/tantangkiwood_display"
            android:text="@string/Back"
            android:textColor="@android:color/black"
            android:textSize="25sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/navigation_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
