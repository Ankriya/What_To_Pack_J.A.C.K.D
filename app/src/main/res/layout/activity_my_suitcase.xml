<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MySuitcaseActivity">

    <!-- Main content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/beige"
        tools:context=".MySuitcaseActivity">

        <!-- Hamburger menu button -->
        <ImageButton
            android:id="@+id/menu_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:contentDescription="Menu"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:tint="@color/black"/>

        <TextView
            android:id="@+id/MySuitcase"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/tantangkiwood_display"
            android:gravity="center"
            android:text="@string/MY_SUITCASE"
            android:textColor="@color/black"
            android:textSize="55sp"
            app:layout_constraintTop_toBottomOf="@id/menu_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/TripDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:srcCompat="@drawable/suitcase"
            app:layout_constraintTop_toBottomOf="@id/MySuitcase"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/TripDetailsBtn"
            android:layout_width="142dp"
            android:layout_height="91dp"
            android:fontFamily="@font/tantangkiwood_display"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:rotation="12"
            android:text="@string/TripDetails"
            android:textColor="@color/black"
            android:textSize="40sp"
            app:backgroundTint="@android:color/transparent"
            app:layout_constraintBottom_toBottomOf="@id/TripDetails"
            app:layout_constraintEnd_toEndOf="@id/TripDetails"
            app:layout_constraintHorizontal_bias="0.385"
            app:layout_constraintStart_toStartOf="@id/TripDetails"
            app:layout_constraintTop_toTopOf="@id/TripDetails"
            app:layout_constraintVertical_bias="0.567"/>

        <ImageView
            android:id="@+id/MyList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:srcCompat="@drawable/suitcase2"
            app:layout_constraintTop_toBottomOf="@id/TripDetails"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/MyListBtn"
            android:layout_width="117dp"
            android:layout_height="111dp"
            android:fontFamily="@font/tantangkiwood_display"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:rotation="-9"
            android:text="@string/MyList"
            android:textColor="@color/black"
            android:textSize="50sp"
            app:backgroundTint="@android:color/transparent"
            app:layout_constraintBottom_toBottomOf="@id/MyList"
            app:layout_constraintEnd_toEndOf="@id/MyList"
            app:layout_constraintHorizontal_bias="0.497"
            app:layout_constraintStart_toStartOf="@id/MyList"
            app:layout_constraintTop_toTopOf="@id/MyList"
            app:layout_constraintVertical_bias="0.461"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/navigation_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>
