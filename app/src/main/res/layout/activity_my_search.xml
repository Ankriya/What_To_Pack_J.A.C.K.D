<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sky_blue"
    tools:context=".MySearchActivity">

    <TextView
        android:id="@+id/mySearch"
        android:layout_width="350dp"
        android:layout_height="82dp"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/tantangkiwood_display"
        android:text="MY SEARCH"
        android:textColor="@color/black"
        android:textSize="75sp"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="46dp" />

    <ImageView
        android:id="@+id/grass"
        android:layout_width="433dp"
        android:layout_height="824dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@+id/mySearch"
        app:srcCompat="@drawable/redcar_restaurant_money"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="-11dp" />

    <ImageView
        android:id="@+id/clouds"
        android:layout_width="228dp"
        android:layout_height="154dp"
        app:layout_constraintTop_toBottomOf="@+id/mySearch"
        app:srcCompat="@drawable/clouds"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="186dp" />

    <ImageView
        android:id="@+id/calendar"
        android:layout_width="179dp"
        android:layout_height="171dp"
        android:layout_marginRight="8dp"
        app:layout_constraintRight_toLeftOf="@+id/clouds"
        app:srcCompat="@drawable/calendar"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteY="186dp" />

    <Button
        android:id="@+id/WeatherBtn"
        android:layout_width="144dp"
        android:layout_height="66dp"
        android:layout_marginTop="80dp"
        android:fontFamily="@font/tantangkiwood_display"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="WEATHER"
        android:textColor="@color/black"
        android:textSize="30sp"
        app:backgroundTint="@color/transparent"
        app:layout_constraintTop_toTopOf="@+id/clouds"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="211dp" />

    <Button
        android:id="@+id/EventsBtn"
        android:layout_width="155dp"
        android:layout_height="101dp"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/tantangkiwood_display"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="EVENTS"
        android:textColor="@color/black"
        android:textSize="30sp"
        app:backgroundTint="@color/transparent"
        app:layout_constraintTop_toTopOf="@+id/calendar"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="16dp" />

    <Button
        android:id="@+id/RestaurantBtn"
        android:layout_width="196dp"
        android:layout_height="136dp"
        android:layout_marginTop="280dp"
        android:fontFamily="@font/tantangkiwood_display"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="RESTAURANTS"
        android:textColor="@color/black"
        android:textSize="30sp"
        app:backgroundTint="@color/transparent"
        app:layout_constraintTop_toTopOf="@+id/grass"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="199dp" />

    <Button
        android:id="@+id/CurrencyBtn"
        android:layout_width="144dp"
        android:layout_height="66dp"
        android:layout_marginTop="552dp"
        android:fontFamily="@font/tantangkiwood_display"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="CURRENCY"
        android:textColor="@color/black"
        android:textSize="30sp"
        app:backgroundTint="@color/transparent"
        app:layout_constraintTop_toTopOf="@+id/grass"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="270dp" />

    <Button
        android:id="@+id/TransportBtn"
        android:layout_width="140dp"
        android:layout_height="41dp"
        android:layout_marginTop="500dp"
        android:fontFamily="@font/tantangkiwood_display"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="TRANSPORT"
        android:textColor="@color/black"
        android:textSize="30sp"
        app:backgroundTint="@color/transparent"
        app:layout_constraintTop_toTopOf="@+id/grass"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="-1dp" />

</androidx.constraintlayout.widget.ConstraintLayout>